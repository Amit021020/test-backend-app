<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="h-screen">
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white" flex >
        <div class="w-full flex justify-end"><a href="/logout" class="bg-red-500 inline-block text-sm mb-5 rounded-md  px-3 py-2">Logout</a></div>
        <div class="flex items-start gap-3">
            <div class="image w-10 h-10 rounded-md">
                <img src="images/uploads/<%=user.profilepic%>" alt="">
            </div>
            <h1 class="text-3xl tracking-tighter mb-5">Hello , <%= user.name %>  </h1>

        </div>
        <h3>You can create a post!</h3>
        <form action="/post" method="post">
            <textarea name="content" class="mt-2 block bg-transparent resize-none border-2 border-zinc-600 outline-none w-1/3 p-3 rounded-md" placeholder="What's in your mind?"></textarea>
            <input type="submit" class="w-40 text-sm mt-2 bg-blue-600 px-3 py-2 block rounded-md" value="Create Post">
        </form>
        <div class="posts mt-20">
            <h3 class="text-zinc-600">Your Posts</h3>
            <div class="postcontainer mt-2">
                <% user.posts.reverse().forEach(function(post){ %>
                    <div class="post mb-4 w-1/3 border-1 border-zinc-600 rounded-md p-4 ">
                    <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>
                        <p class="text-sm tracking-tight"><%= post.content %></p>
                        <small class="mt-2 inline-block"><%=post.likes.length%></small>
                        <div class="btns flex mt-5 gap-8 mt-1">
                            <a href="/like/<%= post._id %>" class="text-pink-500"><%= post.likes.indexOf(user._id) === -1? "Like" : "Unlike"%></a>
                            <a href="/edit/<%= post._id%>" class="text-blue-500">Edit</a>
                        </div>
                    </div>

                <% }) %>
            </div>
        </div>
    </div>
    
</body>
</html>