<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="h-screen">
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white" flex >
        <h3>Edit your post!</h3>
        <form action="/update/<%= post._id %>" method="post">
            <textarea name="content"  class="mt-2 block bg-transparent resize-none border-2 border-zinc-600 outline-none w-1/3 p-3 rounded-md"><%=post.content%></textarea>
            <input type="submit" class="w-40 text-sm mt-2 bg-purple-600 px-3 py-2 block rounded-md" value="Create Post">
        </form>
    </div>
    
</body>
</html>